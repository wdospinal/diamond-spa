# COP per 1 USD (shown in admin next to dollar amounts). Used at build time on the client.
NEXT_PUBLIC_COP_PER_USD=4100

# Google Places API — autocomplete, place details, etc.
# Create a key in Google Cloud Console and restrict it by API + HTTP referrer (web) or IP (server).
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Twilio — SMS notifications for new bookings
# Sign up at https://www.twilio.com and get these from your Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number

# The spa's phone that receives booking SMS notifications
BUSINESS_PHONE=+573145484227

# Admin app (https://app.diamondspa.com.co rewrites to /admin — or open /admin locally)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
# Random string for signing the admin session cookie (e.g. openssl rand -hex 32)
ADMIN_SESSION_SECRET=

# Optional: JSON file path for bookings (default: ./data/bookings.json). Serverless hosts need a DB instead.
# BOOKINGS_FILE=/var/lib/diamond-spa/bookings.json

# Optional: manual income/expense ledger (default: ./data/ledger.json)
# LEDGER_FILE=/var/lib/diamond-spa/ledger.json

# Resend — email notifications for new bookings (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
