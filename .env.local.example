# COP per 1 USD (shown in admin next to dollar amounts). Used at build time on the client.
NEXT_PUBLIC_COP_PER_USD=4100

# Google Places API — autocomplete, place details, etc.
# Create a key in Google Cloud Console and restrict it by API + HTTP referrer (web) or IP (server).
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Twilio — SMS notifications for new bookings
# Sign up at https://www.twilio.com and get these from your Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number

# The spa's phone that receives booking SMS notifications
BUSINESS_PHONE=+573054541635

# Admin app (https://app.diamondspa.com.co rewrites to /admin — or open /admin locally)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
# Random string for signing the admin session cookie (e.g. openssl rand -hex 32)
ADMIN_SESSION_SECRET=

# Optional: JSON file path for bookings (default: ./data/bookings.json). Serverless hosts need a DB instead.
# BOOKINGS_FILE=/var/lib/diamond-spa/bookings.json

# Optional: manual income/expense ledger (default: ./data/ledger.json)
# LEDGER_FILE=/var/lib/diamond-spa/ledger.json

# Resend — email notifications for new bookings (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Web Push notifications (admin new-booking / check-in alerts) ─────────────
# VAPID keys identify this server to the browser push services. Generate a pair
# with:  npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the browser (NEXT_PUBLIC_*); keep PRIVATE secret.
# Subscriptions are stored in Vercel KV in production (see KV_REST_API_* below)
# and fall back to data/push-subs.json locally — that file is gitignored because
# it holds users' device push keys and must never be committed.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@diamondspa.com

# ─── Sales funnel dashboard (/admin/funnel) ──────────────────────────────────
# Web Analytics events are pushed to /api/analytics-drain via a Vercel Analytics
# Drain (Project → Drains → New Drain → Analytics, HTTP delivery, JSON encoding,
# endpoint https://<your-domain>/api/analytics-drain). Drains require a Pro plan.
# Paste the drain's signing secret here so the webhook can verify x-vercel-signature.
# For local testing, set any value and sign your test payload with the same secret.
VERCEL_DRAIN_SECRET=

# Durable store for the aggregated funnel counters. Connect a Vercel KV / Upstash
# Redis store to the project and these are injected automatically (UPSTASH_REDIS_*
# also accepted). Without them the app falls back to a local JSON file
# (data/funnel-daily.json) — fine for local dev, but NOT durable on Vercel's
# ephemeral filesystem, so set these in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: JSON file path for the local funnel fallback (default: ./data/funnel-daily.json)
# FUNNEL_FILE=/var/lib/diamond-spa/funnel-daily.json
